{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinDevDependencies",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests"
  ],
  "assignees": [
    "sylvainmetayer"
  ],
  "addLabels": [
    "dependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [".*\\.ya?ml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\n]+?)(?:\\s+extractVersion=(?<extractVersion>[^\\n]+?))?\\n\\s+generic_app_url: \\\"[^\\\"]*?(?<currentValue>[0-9]+(?:\\.[0-9]+)+)\\\""
      ]
    }
  ]
}
